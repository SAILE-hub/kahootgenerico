{
  "version": 2,
  "buildCommand": "echo 'Static files ready'",
  "builds": [
    {
      "src": "src/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/socket.io/(.*)",
      "dest": "https://kahootgenerico-production.up.railway.app/socket.io/$1",
      "headers": {
        "Connection": "Upgrade"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "https://kahootgenerico-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/index.html"
    }
  ]
}
